{
  "name": "surevision-ai-desktop",
  "version": "1.0.0",
  "description": "SureVision AI - Enterprise Decision Intelligence Desktop Application",
  "main": "dist/main/main.js",
  "author": "SureVision AI",
  "license": "MIT",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.surevision.ai.desktop",
    "productName": "SureVision AI",
    "directories": {
      "output": "output"
    },
    "files": [
      "dist/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-log": "^5.2.0",
    "electron-store": "^8.2.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0"
  }
}
